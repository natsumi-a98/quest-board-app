{
	"name": "backend",
	"private": true,
	"scripts": {
		"dev": "tsx watch src/app.ts",
		"build": "tsc",
		"openapi:diff-to-zod": "tsx scripts/openapiDiffToZod.ts",
		"prisma:generate": "prisma generate --schema prisma/schema.prisma",
		"prisma:db:push": "prisma db push --schema prisma/schema.prisma",
		"prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
		"seed": "tsx prisma/seed.ts",
		"seed:inactive": "tsx prisma/add-inactive-quests.ts",
		"start": "node dist/app.js",
		"test": "jest",
		"typecheck": "tsc --noEmit",
		"test:prepush": "pnpm typecheck && pnpm test --runInBand",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage"
	},
	"prisma": {
		"seed": "tsx prisma/seed.ts"
	},
	"dependencies": {
		"@asteasolutions/zod-to-openapi": "^7.3.4",
		"@prisma/client": "5.22.0",
		"@quest-board/types": "workspace:*",
		"cors": "^2.8.5",
		"dotenv": "^16.0.0",
		"express": "^4.18.0",
		"firebase-admin": "^13.7.0",
		"helmet": "^7.0.0",
		"pino": "^10.3.1",
		"pino-http": "^11.0.0",
		"pino-pretty": "^13.1.3",
		"prisma": "^5.22.0",
		"swagger-ui-express": "^5.0.1",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@types/cors": "^2.8.0",
		"@types/express": "^4.17.0",
		"@types/jest": "^29.5.0",
		"@types/node": "^20.0.0",
		"@types/swagger-ui-express": "^4.1.8",
		"jest": "^29.5.0",
		"nodemon": "^3.0.0",
		"ts-jest": "^29.1.0",
		"tsx": "^4.0.0",
		"typescript": "^5.0.0"
	}
}
